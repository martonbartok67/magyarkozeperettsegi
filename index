        /* --- PORTAL STATE LOGIC --- */
        let currentModule = 'grammar';

        function setModule(moduleName) {
            currentModule = moduleName;
            
            const btnGrammar = document.getElementById('btnGrammar');
            const btnLiterature = document.getElementById('btnLiterature');
            const portalHeadline = document.getElementById('portalHeadline');
            
            if (moduleName === 'grammar') {
                btnGrammar.classList.add('active');
                btnLiterature.classList.remove('active');
                portalHeadline.innerText = "Nyelvtan Szóbeli Tételek";
            } else {
                btnGrammar.classList.remove('active');
                btnLiterature.classList.add('active');
                portalHeadline.innerText = "Irodalom Szóbeli Tételek";
            }

            renderCards();
            renderMenuItems();
        }

        function renderCards() {
            const grid = document.getElementById('cardsGrid');
            grid.innerHTML = '';
            const dataSet = currentModule === 'grammar' ? grammarData : literatureData;

            dataSet.forEach(item => {
                const card = document.createElement('div');
                card.className = 'topic-card';
                card.onclick = () => openStudyDrawer(item.id);

                // Create clean preview from text
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = item.text;
                const cleanText = tempDiv.textContent || tempDiv.innerText || "";

                card.innerHTML = `
                    <div>
                        <div class="card-meta">${currentModule === 'grammar' ? 'Nyelvtan' : 'Irodalom'} • ${item.id}. Tétel</div>
                        <div class="card-title">${item.title}</div>
                    </div>
                    <div class="card-preview">${cleanText}</div>
                `;
                grid.appendChild(card);
            });
        }

        /* --- STUDY DRAWER LOGIC --- */
        function openStudyDrawer(id) {
            const dataSet = currentModule === 'grammar' ? grammarData : literatureData;
            const item = dataSet.find(x => x.id === id);
            if (!item) return;

            document.getElementById('drawerBadge').innerText = `${currentModule === 'grammar' ? 'Nyelvtan' : 'Irodalom'} • ${item.id}. Tétel`;
            document.getElementById('drawerTitle').innerText = item.title;
            // The text maintains exact formatting from the DB objects
            document.getElementById('drawerBody').innerHTML = item.text;

            document.getElementById('studyDrawer').classList.add('open');
        }

        function closeStudyDrawer() {
            document.getElementById('studyDrawer').classList.remove('open');
        }

        /* --- GSAP STAGGERED MENU IMPLEMENTATION (VANILLA JS PORT) --- */
        let menuOpen = false;
        let isAnimating = false;

        const menuToggleBtn = document.getElementById('menuToggleBtn');
        const staggeredMenuPanel = document.getElementById('staggeredMenuPanel');
        const preLayers = Array.from(document.querySelectorAll('.sm-prelayer'));
        const smIconH = document.getElementById('smIconH');
        const smIconV = document.getElementById('smIconV');
        const textInner = document.getElementById('smToggleTextInner');
        const menuItemsContainer = document.getElementById('menuItemsContainer');

        function renderMenuItems() {
            menuItemsContainer.innerHTML = '';
            const dataSet = currentModule === 'grammar' ? grammarData : literatureData;

            dataSet.forEach((item, index) => {
                const li = document.createElement('li');
                li.className = 'sm-panel-itemWrap';
                li.innerHTML = `
                    <a class="sm-panel-item" href="#" onclick="handleMenuLinkClick(event, ${item.id})">
                        <span class="sm-panel-itemLabel">${item.title.split('(')[0].trim()}</span>
                    </a>
                `;
                menuItemsContainer.appendChild(li);
            });
        }

        function handleMenuLinkClick(e, id) {
            e.preventDefault();
            toggleMenu(false);
            setTimeout(() => {
                openStudyDrawer(id);
            }, 500); // Wait for menu exit animation
        }

        // Initialize GSAP baseline states
        gsap.set([staggeredMenuPanel, ...preLayers], { xPercent: 100, opacity: 1 });
        gsap.set(document.querySelector('.sm-prelayers'), { xPercent: 0, opacity: 1 });
        gsap.set(smIconH, { transformOrigin: '50% 50%', rotate: 0 });
        gsap.set(smIconV, { transformOrigin: '50% 50%', rotate: 90 });
        gsap.set(textInner, { yPercent: 0 });

        // Initialize text rows for cycle animation
        textInner.innerHTML = `
            <span class="sm-toggle-line">Menu</span>
            <span class="sm-toggle-line">Close</span>
            <span class="sm-toggle-line">Menu</span>
            <span class="sm-toggle-line">Close</span>
        `;

        function toggleMenu(targetState) {
            if (isAnimating) return;
            const openTarget = targetState !== undefined ? targetState : !menuOpen;
            if (menuOpen === openTarget) return;

            menuOpen = openTarget;
            isAnimating = true;

            const wrapper = document.getElementById('staggeredMenuContainer');
            if (menuOpen) wrapper.setAttribute('data-open', 'true');
            else wrapper.removeAttribute('data-open');

            menuToggleBtn.setAttribute('aria-expanded', menuOpen);
            staggeredMenuPanel.setAttribute('aria-hidden', !menuOpen);

            const itemLabels = Array.from(staggeredMenuPanel.querySelectorAll('.sm-panel-itemLabel'));
            const socialLinks = Array.from(staggeredMenuPanel.querySelectorAll('.sm-socials-link'));

            if (menuOpen) {
                // Prepare Entry State
                gsap.set(itemLabels, { yPercent: 140, rotate: 10 });
                gsap.set(socialLinks, { y: 25, opacity: 0 });

                const tl = gsap.timeline({ onComplete: () => { isAnimating = false; }});
                
                // Slatted underlay slide-ins
                preLayers.forEach((layer, idx) => {
                    tl.fromTo(layer, { xPercent: 100 }, { xPercent: 0, duration: 0.5, ease: 'power4.out' }, idx * 0.07);
                });
                
                // Main Panel Entry
                tl.fromTo(staggeredMenuPanel, 
                    { xPercent: 100 }, 
                    { xPercent: 0, duration: 0.65, ease: 'power4.out' }, 
                    (preLayers.length - 1) * 0.07 + 0.08
                );

                // Menu Items Lift
                tl.to(itemLabels, {
                    yPercent: 0, rotate: 0, duration: 1, ease: 'power4.out', stagger: 0.08
                }, "-=0.4");

                // Social Links Lift
                tl.to(socialLinks, {
                    y: 0, opacity: 1, duration: 0.55, ease: 'power3.out', stagger: 0.05
                }, "-=0.8");

                // UI Button Animations (Text scroll & Icon spin)
                gsap.to([smIconH, smIconV], { rotate: "+=135", duration: 0.8, ease: 'power4.out' });
                gsap.to(textInner, { yPercent: -75, duration: 0.71, ease: 'power4.out' }); // Scroll to 'Close'

            } else {
                // Exit Animation
                const tl = gsap.timeline({ onComplete: () => { isAnimating = false; }});
                
                tl.to([preLayers[1], preLayers[0], staggeredMenuPanel], {
                    xPercent: 100,
                    duration: 0.4,
                    ease: 'power3.in',
                    stagger: 0.04
                });

                // Revert UI Button
                gsap.to([smIconH, smIconV], { rotate: "-=135", duration: 0.4, ease: 'power3.inOut' });
                gsap.to(textInner, { yPercent: 0, duration: 0.4, ease: 'power3.inOut' }); // Scroll to 'Menu'
            }
        }

        menuToggleBtn.addEventListener('click', () => toggleMenu());

        // Close panels when clicking outside
        document.addEventListener('mousedown', (e) => {
            if (menuOpen && !staggeredMenuPanel.contains(e.target) && !menuToggleBtn.contains(e.target)) {
                toggleMenu(false);
            }
        });

        /* --- INITIALIZATION --- */
        window.addEventListener('DOMContentLoaded', () => {
            setModule('grammar'); // Loads default state
        });
    </script>
